DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Preferred for Render. Use the Internal Database URL when your backend is also on Render.
DATABASE_URL=postgresql://user:password@host:5432/database
# Defaults to True when DATABASE_URL is set.
USE_DATABASE_URL=True

# Optional local PostgreSQL settings when DATABASE_URL is not used.
POSTGRES_DB=kaeve_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
