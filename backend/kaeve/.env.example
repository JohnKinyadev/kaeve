DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Preferred for Render. Use the Internal Database URL when your backend is also on Render.
DATABASE_URL=postgresql://user:password@host:5432/database
# Defaults to True when DJANGO_DEBUG=False and False when DJANGO_DEBUG=True.
USE_DATABASE_URL=False

# Optional local PostgreSQL fallback. Leave POSTGRES_DB empty to use SQLite locally.
POSTGRES_DB=kaeve_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
